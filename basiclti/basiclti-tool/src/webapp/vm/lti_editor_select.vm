<div class="portletBody">
#if ( $allTools )
<style>
.lti_tool_list {
border-bottom: 1px solid gray;
}
</style>
<p>$tlang.getString("contentitem.tools")</p>
<ul>
#foreach($tool in $allTools)
<li>
<p class="lti_tool_list">
#if( $tool.get("fa_icon"))
<i class="fa $tool.get("fa_icon")" aria-hidden="true"></i>
#else
<i class="fa fa-globe" aria-hidden="true"></i>
#end
<a href="$sakai_ActionURL.setPanel("ContentItemMain")&flow=$flow&tool_id=$tool.get("id")&returnUrl=$returnUrl">$tool.get('title')</a>
#if ( $tool.get('pl_linkselection') )
<i class="fa fa-search" style="color:blue;" aria-hidden="true"></i>
#end
#if ( $tool.get('description') )
<br/>
$tool.get('description')
</p>
#end
</li>
#end
</ul>
#else
<p>$tlang.getString("contentitem.notools")</p>
#end
</div>
