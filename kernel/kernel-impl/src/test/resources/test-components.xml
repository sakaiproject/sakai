<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-2.0.xsd">

    <!-- These are defined in the providers module, mocks are needed for testing -->
    <bean id="org.sakaiproject.authz.api.GroupProvider" class="org.mockito.Mockito" factory-method="mock">
        <constructor-arg value="org.sakaiproject.authz.api.GroupProvider"/>
    </bean>

    <bean id="org.sakaiproject.authz.api.RoleProvider" class="org.mockito.Mockito" factory-method="mock">
        <constructor-arg value="org.sakaiproject.authz.api.RoleProvider"/>
    </bean>
</beans>
