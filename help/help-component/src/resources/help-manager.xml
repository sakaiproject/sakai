<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">


    <bean id="org.sakaiproject.api.app.help.HelpManager"
          class="org.sakaiproject.component.app.help.HelpManagerImpl">
        <property name="restConfiguration" ref="org.sakaiproject.api.app.help.RestConfiguration"/>
        <property name="sessionFactory" ref="helpSessionFactory"/>
        <property name="toolManager" ref="org.sakaiproject.tool.api.ActiveToolManager"/>
        <property name="serverConfigurationService" ref="org.sakaiproject.component.api.ServerConfigurationService"/>
        <property name="txManager" ref="helpTransactionManager"/>
        <property name="userDirectoryService" ref="org.sakaiproject.user.api.UserDirectoryService"/>
        <property name="preferencesService" ref="org.sakaiproject.user.api.PreferencesService"/>
    </bean>

    <bean id="org.sakaiproject.api.app.help.RestConfiguration"
          class="org.sakaiproject.component.app.help.RestConfigurationImpl">
        <property name="organization" value="sakai"/>
        <property name="restCredentials" value="user:pass"/>
        <property name="restUrl" value="http://"/>
        <property name="restDomain" value="sakaihelp"/>
        <property name="cacheInterval" value="7200000"/>
    </bean>

</beans>